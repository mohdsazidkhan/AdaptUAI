# JWT secret
JWT_SECRET=your_jwt_secret_here

# OpenAI API key
# OPENAI_API_KEY=sk-proj-...

# Optional: OpenAI model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

OPENROUTER_API_KEY=sk-.......................
AI_BASE_URL=https://openrouter.ai/api/v1
