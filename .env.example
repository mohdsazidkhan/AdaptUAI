AI_MODEL2=google/gemma-2-9b-it:free
AI_MODEL3=qwen/qwen-2.5-72b-instruct:free
AI_MODEL4=mistralai/pixtral-12b:free
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
